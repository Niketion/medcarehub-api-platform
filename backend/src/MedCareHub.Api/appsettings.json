{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "Auth": {
    "Authority": "http://localhost:8081/realms/medcarehub",
    "ValidateAudience": false,
    "Audience": "medcarehub-api"
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=medcarehub;Username=postgres;Password=postgres"
  },
  "Storage": {
    "Endpoint": "http://localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "Bucket": "reports"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "AllowedHosts": "*"
}
