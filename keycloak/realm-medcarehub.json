{
  "realm": "medcarehub",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "clients": [
    {
      "clientId": "medcarehub-web",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    },
    {
      "clientId": "medcarehub-api",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "protocol": "openid-connect"
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "patient"
      },
      {
        "name": "operator"
      },
      {
        "name": "doctor"
      },
      {
        "name": "admin"
      }
    ]
  },
  "users": [
    {
      "username": "patient1",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Patient",
      "lastName": "One",
      "email": "patient1@example.local",
      "credentials": [
        {
          "type": "password",
          "value": "Password!23",
          "temporary": false
        }
      ],
      "realmRoles": [
        "patient"
      ]
    },
    {
      "username": "operator1",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Operator",
      "lastName": "One",
      "email": "operator1@example.local",
      "credentials": [
        {
          "type": "password",
          "value": "Password!23",
          "temporary": false
        }
      ],
      "realmRoles": [
        "operator"
      ]
    }
  ]
}